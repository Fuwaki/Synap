<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="desktop_windows.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:desktop_windows"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Margin="36,0,36,24" Spacing="8">
            <!-- 外观标题 -->
            <TextBlock 
                Text="外观" 
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Margin="0,0,0,4" />

            <!-- 主题设置卡片 -->
            <Border 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <FontIcon 
                        Grid.Column="0"
                        Glyph="&#xE771;"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center" />
                    
                    <StackPanel 
                        Grid.Column="1"
                        VerticalAlignment="Center">
                        <TextBlock 
                            Text="主题" 
                            Style="{ThemeResource BodyTextBlockStyle}" />
                        <TextBlock 
                            Text="选择应用的外观主题" 
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    
                    <ComboBox 
                        x:Name="ThemeComboBox" 
                        Grid.Column="2"
                        Width="150"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        SelectionChanged="ThemeComboBox_SelectionChanged">
                        <ComboBoxItem Content="浅色" Tag="Light" />
                        <ComboBoxItem Content="深色" Tag="Dark" />
                        <ComboBoxItem Content="跟随系统" Tag="Default" />
                    </ComboBox>
                </Grid>
            </Border>

            <!-- 语言标题 -->
            <TextBlock 
                Text="语言" 
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Margin="0,8,0,4" />

            <!-- 语言设置卡片 -->
            <Border 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <FontIcon 
                        Grid.Column="0"
                        Glyph="&#xE774;"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center" />
                    
                    <StackPanel 
                        Grid.Column="1"
                        VerticalAlignment="Center">
                        <TextBlock 
                            Text="应用语言" 
                            Style="{ThemeResource BodyTextBlockStyle}" />
                        <TextBlock 
                            Text="选择应用显示语言" 
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    
                    <ComboBox 
                        x:Name="LanguageComboBox" 
                        Grid.Column="2"
                        Width="150"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        SelectedIndex="0">
                        <ComboBoxItem Content="简体中文" Tag="zh-CN" />
                        <ComboBoxItem Content="繁體中文 (TW)" Tag="zh-TW" />
                        <ComboBoxItem Content="繁體中文 (HK)" Tag="zh-HK" />
                        <ComboBoxItem Content="English" Tag="en" />
                        <ComboBoxItem Content="한국어" Tag="ko" />
                        <ComboBoxItem Content="日本語" Tag="ja" />
                    </ComboBox>
                </Grid>
            </Border>

            <!-- 关于标题 -->
            <TextBlock 
                Text="关于" 
                Style="{ThemeResource BodyStrongTextBlockStyle}"
                Margin="0,8,0,4" />

            <!-- 关于卡片 -->
            <Border 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
                <StackPanel Spacing="4">
                    <TextBlock 
                        Text="Synap" 
                        Style="{ThemeResource TitleLargeTextBlockStyle}" />
                    <TextBlock 
                        Text="一款极简风格的笔记软件，用于快速捕获思维。" 
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <HyperlinkButton 
                        Content="https://synap.rth1.xyz/"
                        NavigateUri="https://synap.rth1.xyz/"
                        Margin="0,4,0,0" />
                    <HyperlinkButton 
                        Content="https://github.com/VilinkoStudio/Synap"
                        NavigateUri="https://github.com/VilinkoStudio/Synap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
